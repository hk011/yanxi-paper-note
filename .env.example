# MinerU PDF 解析（https://mineru.net 申请）
mineru_api_token=
mineru_base_url=https://mineru.net/api

# 火山方舟（https://console.volcengine.com/ark 申请）
ark_key=
ark_url=https://ark.cn-beijing.volces.com/api/v3
# 多模态大模型，多个 ID 用英文逗号分隔
ark_multi_model_list=
# 图像生成，推荐 Seedream 5.0
ark_image_gen_model=doubao-seedream-5-0-260128
# 小节配图提示词优化（多模态，需支持 input_image）
ark_figure_optimizer_model=doubao-seed-2-0-lite-260428

# 千帆百度搜索 MCP（自定义模型联网搜索，streamableHttp）
web_search_mcp_server=https://qianfan.baidubce.com/v2/tools/web-search/mcp
web_search_mcp_server_key=

# JWT 签名密钥（生产环境务必改为随机长字符串，如 openssl rand -hex 32）
jwt_secret=
jwt_expire_hours=72
